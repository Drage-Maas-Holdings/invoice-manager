---
import Layout from '../../layouts/Layout.astro';
import ThemeToggle from '../../components/ThemeToggle.astro';
import { invoiceRepository } from '../../repositories/invoice.sqlite';

const vendorId = (Astro.locals.actor as { vendor_id: string }).vendor_id;
const invoices = invoiceRepository.findByVendor(vendorId);
---
<Layout title="Vendor Portal">
  <div class="mx-auto max-w-5xl p-4">
    <div class="mb-6 flex items-center justify-between">
      <h1 class="text-2xl font-semibold text-text">Vendor Portal</h1>
      <div class="flex items-center gap-4">
        <ThemeToggle />
        <form id="logout-form" method="POST" action="/api/auth/logout">
          <button type="submit" class="rounded border border-border px-3 py-1 text-text hover:bg-surface">Log out</button>
        </form>
      </div>
    </div>

    <div class="mb-8 overflow-x-auto rounded-lg border border-border">
      <table class="w-full text-left text-sm text-text">
        <thead class="bg-surface">
          <tr>
            <th class="px-4 py-2">Invoice #</th>
            <th class="px-4 py-2">PO Reference</th>
            <th class="px-4 py-2">Amount</th>
            <th class="px-4 py-2">Currency</th>
            <th class="px-4 py-2">Due Date</th>
            <th class="px-4 py-2">Status</th>
            <th class="px-4 py-2">Match</th>
          </tr>
        </thead>
        <tbody>
          {invoices.length === 0 && (
            <tr><td colspan="7" class="px-4 py-4 text-center text-text-muted">No invoices found.</td></tr>
          )}
          {invoices.map(inv => (
            <tr class="border-t border-border">
              <td class="px-4 py-2">{inv.invoice_number}</td>
              <td class="px-4 py-2">{inv.po_reference}</td>
              <td class="px-4 py-2">{inv.amount.toFixed(2)}</td>
              <td class="px-4 py-2">{inv.currency}</td>
              <td class="px-4 py-2">{inv.due_date?.toLocaleDateString() ?? '—'}</td>
              <td class="px-4 py-2">{inv.status.replace(/_/g, ' ')}</td>
              <td class="px-4 py-2">{inv.match_status.replace(/_/g, ' ')}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <div class="rounded-lg border border-border bg-surface p-6">
      <h2 class="mb-4 text-lg font-semibold text-text">Submit Invoice</h2>
      <form id="submit-form" class="grid grid-cols-1 gap-4 sm:grid-cols-2">
        <div>
          <label for="invoice_number" class="mb-1 block text-sm font-medium text-text">Invoice Number *</label>
          <input id="invoice_number" name="invoice_number" type="text" required class="w-full rounded border border-border bg-background px-3 py-2 text-text" />
        </div>
        <div>
          <label for="po_reference" class="mb-1 block text-sm font-medium text-text">PO Reference *</label>
          <input id="po_reference" name="po_reference" type="text" required class="w-full rounded border border-border bg-background px-3 py-2 text-text" />
        </div>
        <div>
          <label for="amount" class="mb-1 block text-sm font-medium text-text">Amount *</label>
          <input id="amount" name="amount" type="number" step="0.01" min="0.01" required class="w-full rounded border border-border bg-background px-3 py-2 text-text" />
        </div>
        <div>
          <label for="currency" class="mb-1 block text-sm font-medium text-text">Currency *</label>
          <input id="currency" name="currency" type="text" required class="w-full rounded border border-border bg-background px-3 py-2 text-text" />
        </div>
        <div>
          <label for="due_date" class="mb-1 block text-sm font-medium text-text">Due Date</label>
          <input id="due_date" name="due_date" type="date" class="w-full rounded border border-border bg-background px-3 py-2 text-text" />
        </div>
        <div>
          <label for="supersedes_invoice_id" class="mb-1 block text-sm font-medium text-text">Supersedes Invoice ID</label>
          <input id="supersedes_invoice_id" name="supersedes_invoice_id" type="text" class="w-full rounded border border-border bg-background px-3 py-2 text-text" />
        </div>
        <div class="sm:col-span-2">
          <p id="submit-error" class="mb-3 hidden text-sm text-red-500"></p>
          <button type="submit" class="rounded bg-accent px-4 py-2 font-medium text-carbon_black-500 transition hover:bg-accent-strong">Submit Invoice</button>
        </div>
      </form>
    </div>
  </div>
  <script>
    document.getElementById('logout-form')?.addEventListener('submit', async (e) => {
      e.preventDefault();
      await fetch('/api/auth/logout', { method: 'POST' });
      window.location.href = '/vendor/login';
    });

    document.getElementById('submit-form')?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const form = e.currentTarget;
      const data = new FormData(form);
      const errorEl = document.getElementById('submit-error');
      errorEl.classList.add('hidden');

      const due_date = data.get('due_date');
      const supersedes_invoice_id = data.get('supersedes_invoice_id');

      const body = {
        invoice_number: data.get('invoice_number'),
        po_reference: data.get('po_reference'),
        amount: parseFloat(data.get('amount')),
        currency: data.get('currency'),
      };
      if (due_date) body.due_date = due_date;
      if (supersedes_invoice_id) body.supersedes_invoice_id = supersedes_invoice_id;

      const res = await fetch('/api/vendor/invoices', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      });

      if (res.ok) {
        window.location.reload();
      } else {
        const err = await res.json();
        errorEl.textContent = err.error || 'Submission failed';
        errorEl.classList.remove('hidden');
      }
    });
  </script>
</Layout>
