---
import Layout from '../../layouts/Layout.astro';
import ThemeToggle from '../../components/ThemeToggle.astro';
import Icon from '../../components/Icon.astro';
import { invoiceRepository } from '../../repositories/invoice.sqlite';
import { vendorRepository } from '../../repositories/vendor.sqlite';
import { bucketOutstandingLiabilities } from '../../lib/invoice-reporting';

const invoices = invoiceRepository.list();
const vendorNames = new Map(vendorRepository.list().map(v => [v.id, v.name]));
const kpis = bucketOutstandingLiabilities(invoices, new Date());

const kpiLabels: Record<string, string> = {
  overdue: 'Overdue',
  this_week: 'This Week',
  this_month: 'This Month',
  later: 'Later',
  undated: 'Undated',
};

function statusPillClass(status: string): string {
  if (status === 'reconciled') return 'status-pill--done';
  if (status === 'rejected') return 'status-pill--rejected';
  if (status === 'approved' || status === 'ready_for_payment') return 'status-pill--active';
  return 'status-pill--pending';
}

function matchPillClass(match: string): string {
  if (match === 'matched') return 'status-pill--done';
  if (match === 'unmatched') return 'status-pill--rejected';
  return 'status-pill--neutral';
}
---
<Layout title="Staff Dashboard">
  <div class="page-shell">
    <div class="mb-6 flex items-center justify-between">
      <h1 class="page-title">Invoices</h1>
      <div class="flex items-center gap-4">
        <ThemeToggle />
        <form id="logout-form" method="POST" action="/api/auth/logout">
          <button type="submit" class="action-btn action-btn--primary flex items-center gap-1.5">
            <Icon name="logout" /> Log out
          </button>
        </form>
      </div>
    </div>

    <div class="mb-8 grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-5">
      {Object.entries(kpis).map(([key, val]) => (
        <div class="kpi-card">
          <div class="kpi-card-label">{kpiLabels[key] ?? key}</div>
          <div class="kpi-card-value">{val.total.toFixed(2)}</div>
          <div class="caption">{val.count} invoice{val.count !== 1 ? 's' : ''}</div>
        </div>
      ))}
    </div>

    <div class="table-container">
      <table class="data-table">
        <thead>
          <tr>
            <th>Vendor</th>
            <th>Invoice #</th>
            <th>PO Reference</th>
            <th class="numeric">Amount</th>
            <th>Currency</th>
            <th>Due Date</th>
            <th>Status</th>
            <th>Match</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          {invoices.length === 0 && (
            <tr><td colspan="9" class="px-4 py-8 text-center caption">No invoices found.</td></tr>
          )}
          {invoices.map(inv => (
            <tr>
              <td class="font-medium">{vendorNames.get(inv.vendor_id) ?? inv.vendor_id}</td>
              <td class="tabular-nums">{inv.invoice_number}</td>
              <td class="tabular-nums">{inv.po_reference}</td>
              <td class="numeric">{inv.amount.toFixed(2)}</td>
              <td>{inv.currency}</td>
              <td class="tabular-nums">{inv.due_date?.toLocaleDateString() ?? '—'}</td>
              <td><span class={`status-pill ${statusPillClass(inv.status)}`}>{inv.status.replace(/_/g, ' ')}</span></td>
              <td><span class={`status-pill ${matchPillClass(inv.match_status)}`}>{inv.match_status.replace(/_/g, ' ')}</span></td>
              <td>
                <a href={`/staff/invoices/${inv.id}`} class="inline-flex items-center gap-1 text-sm font-medium text-text-muted hover:text-text transition-colors">
                  <Icon name="eye" /> View
                </a>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
  <script>
    document.getElementById('logout-form')?.addEventListener('submit', async (e) => {
      e.preventDefault();
      await fetch('/api/auth/logout', { method: 'POST' });
      window.location.href = '/staff/login';
    });
  </script>
</Layout>
